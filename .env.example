# ─── Vista config (all optional for the mock demo) ───────
# Vista currently runs on a MOCK backend (src/lib/api.js): projects, members,
# access requests and the "Démo" roadmap data are all simulated in localStorage.
# None of the variables below are required to run or test the app.

# The Vista product's own repo — used by the landing "View on GitHub" link
# and the footer. Public, not secret.
VITE_VISTA_GITHUB=https://github.com/zestones/vista

# Default GitHub source for projects created with source = "GitHub", and the
# repo the (optional) serverless issue function writes to. Public, not secret.
VITE_GITHUB_OWNER=zestones
VITE_GITHUB_REPO=Aria

# Optional, LOCAL DEV ONLY: a read token for GitHub-backed projects, to dodge
# the 60 req/hr unauthenticated limit or read a private repo while developing.
# ⚠ Anything prefixed VITE_ is bundled into the client. Leave empty in prod.
VITE_GITHUB_TOKEN=

# ─── Future real backend (not used by the mock app) ──────
# The serverless function api/create-issue.js is kept as a reference for when
# the request form is wired to a real GitHub backend. Server-side only.
GITHUB_TOKEN=
GITHUB_OWNER=zestones
GITHUB_REPO=Aria
