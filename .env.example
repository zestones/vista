# ─── Vista — client env (VITE_*) ────────────────────────────────
# Anything prefixed VITE_ is BUNDLED into the browser. Never put a secret here.
# Phase 1 runs on a MOCK adapter (VITE_BACKEND=mock); none of these are required yet.

# Supabase project (public — anon key is safe client-side, protected by RLS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Base URL used to build invite links (#/join/:token). Defaults to window.origin.
VITE_APP_URL=

# Data layer switch: mock | supabase
VITE_BACKEND=mock

# Classic OAuth App client id (#262) — shows the "Connect GitHub for images" button so the owner can
# grant a repo-scoped token that lets the sync re-host private attachment images. Public (client id only;
# the secret stays server-side in supabase/functions/.env). Empty = button hidden.
VITE_GITHUB_OAUTH_CLIENT_ID=

# ─── Server-only secrets (NEVER VITE_*, set in Supabase Edge / secrets) ──────
# Documented in the vault: Projects/Vista/Architecture/Déploiement & environnements.
#   SUPABASE_SERVICE_ROLE_KEY=      # bypass RLS, server only
#   GITHUB_APP_ID=
#   GITHUB_APP_PRIVATE_KEY=         # PEM (RS256)
#   GITHUB_WEBHOOK_SECRET=
#   RESEND_API_KEY=
#
#   # Google OAuth (#12). Local: read by `supabase start` via env() in supabase/config.toml.
#   # Put them in a gitignored .env.local, then: set -a; source .env.local; set +a; npx supabase start
#   SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
#   SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
