# Vista Edge Functions -- SERVER-ONLY secrets (#18). NEVER VITE_*, NEVER committed.
#
# Local:  copy to `supabase/functions/.env` (gitignored) with real values, then:
#           supabase functions serve --env-file supabase/functions/.env
# Deployed: `supabase secrets set --env-file supabase/functions/.env` (Phase 6).
#
# Register the dev GitHub App per Architecture/GitHub App/Configuration & permissions:
#   permissions: Issues (R/W), Metadata (R), Pull requests (R, optional)
#   events: issues, milestone, installation, installation_repositories
#   installable on: Any account

# --- GitHub App (dev) ---
GITHUB_APP_ID=
# The RS256 private key. GitHub issues PKCS#1 ("BEGIN RSA PRIVATE KEY") but the token
# helper imports PKCS#8, so convert then base64 (single-line) in one step:
#   openssl pkcs8 -topk8 -nocrypt -in your-app.private-key.pem | base64 -w0
# The token helper (#21) base64-decodes this back to a PKCS#8 PEM.
GITHUB_APP_PRIVATE_KEY_BASE64=
# Webhook signing secret -- verifies X-Hub-Signature-256 in github-webhook (#23).
GITHUB_WEBHOOK_SECRET=
# Shared secret the sync-repo (#22) function requires as a Bearer -- only the cron (#24) calls it.
#   openssl rand -hex 24
SYNC_TRIGGER_SECRET=
# App OAuth -- REQUIRED by connect-installation (#184): the post-install code is exchanged for the
# caller's user token to verify they own the installation. The App must also have "Request user
# authorization (OAuth) during installation" enabled so GitHub sends ?code= on the post-install redirect.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# --- App ---
# Restricts CORS on browser-invoked functions (e.g. connect-installation #19) to this origin.
# Unset = allow all (fine for local dev); set to the app origin when deployed.
APP_ORIGIN=

# Browser-reachable base for re-hosted attachment URLs (#262). Edge SUPABASE_URL is the internal host
# (kong) in local dev, so set this to the public Supabase origin the BROWSER uses. Unset = fall back to
# SUPABASE_URL (correct in prod). Local dev: http://localhost:54321
STORAGE_PUBLIC_BASE=

# --- Supabase (auto-injected by `supabase functions serve`; set explicitly only when deploying) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=   # Edge functions bypass RLS for projection upserts (#22/#23)
